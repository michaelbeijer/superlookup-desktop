<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- QtWebEngine bundles Chromium, which JITs JavaScript and maps
         executable memory pages. The hardened runtime blocks both by
         default, so these four exceptions are required for the app (and
         the QtWebEngineProcess helper) to run under notarization. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- PyInstaller/Qt load unsigned/third-party dylibs at runtime. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Qt uses DYLD_* env vars to locate its bundled frameworks/plugins. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
