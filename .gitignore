# persistent web sessions (cookies, logins, cache) — never commit
webdata/

# downloaded/parsed EasyList cache
easylist_domains.txt

# per-user settings (enabled searches + custom ones)
config.json

# exported search sets (default filename)
superlookup-searches.json

# python
__pycache__/
*.pyc

# build artifacts (PyInstaller, etc.)
build/
dist/
*.spec

# local screenshots (used for the websites, not part of the app)
superlookup-desktop*.png
